# Resend (https://resend.com)
RESEND_API_KEY=re_xxx_your_api_key

# 신청 메일을 받을 운영자 이메일
CONTACT_EMAIL=hello@yourdomain.com

# 발신 주소. 본인 도메인을 Resend에 검증한 뒤 사용 권장.
# 검증 전이면 onboarding@resend.dev 사용 가능 (수신자만 본인 이메일로 가능)
FROM_EMAIL=Studio <noreply@yourdomain.com>

# /api/apply 이메일 OTP 인증용 HMAC 비밀키.
# 32바이트 이상 권장: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
OTP_SECRET=replace_me_with_32_byte_random_base64
